# ── Aplikacja ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_NAME="Podaruj mi"
FRONTEND_URL=http://localhost:5173

# ── Baza danych ────────────────────────────────────────────────────────────
# Lokalne dev: sqlite+aiosqlite:///./app.db  (lub bez async: sqlite:///./app.db)
# Produkcja:   postgresql+psycopg2://user:pass@host:5432/podaruj_mi
DATABASE_URL=sqlite:///./app.db

# ── Bezpieczenstwo ────────────────────────────────────────────────────────
# Wygeneruj: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-hex-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=43200    # 30 dni
REFRESH_TOKEN_EXPIRE_DAYS=90
ACTIVATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=2

# ── E-mail (Brevo) ─────────────────────────────────────────────────────────
# MAIL_USERNAME = e-mail konta Brevo; MAIL_PASSWORD = klucz SMTP (Brevo → SMTP & API)
MAIL_USERNAME=twoj-email@konta-brevo.pl
MAIL_PASSWORD=your-brevo-smtp-key
MAIL_FROM=noreply@podaruj-mi.pl
MAIL_SERVER=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── Supabase Storage (awatary) ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=avatars

# ── Rate limiting ──────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=5/minute
GENERAL_RATE_LIMIT=100/minute

# ── Monitoring / logi ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Pozostaw puste, aby wyłączyć Sentry (np. w dev). W prod wklej DSN z sentry.io.
SENTRY_DSN=
# Udział żądań objętych tracingiem wydajności (0.0 = wyłączone, np. 0.1 w prod).
SENTRY_TRACES_SAMPLE_RATE=0.0
